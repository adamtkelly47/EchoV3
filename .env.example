# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real credentials (see Docs/SECURITY.md).

# --- Neon Postgres (see Docs/decisions/ADR_0002, ADR_0006) ---
# Use a dedicated Neon development branch, not a production branch.
# Prefer the pooled ("-pooler") endpoint for the api/worker/scheduler services.
DATABASE_URL=postgresql://<user>:<password>@<endpoint>-pooler.<region>.aws.neon.tech/<database>?sslmode=require

# --- Redis (ephemeral/coordination only — see Docs/decisions/ADR_0002) ---
REDIS_URL=redis://redis:6379/0

# --- Ollama (local inference) ---
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL_NAME=llama3.2:1b

# --- Claude (see Docs/MODEL_ROUTING.md, Docs/decisions/ADR_0004) ---
# Never commit a real key. Leave unset to run with Ollama-only (DEFAULT_MODEL_PROVIDER=ollama).
ANTHROPIC_API_KEY=<your-anthropic-api-key>
CLAUDE_MODEL_NAME=claude-sonnet-5

# --- Model gateway (Docs/MODEL_ROUTING.md) ---
DEFAULT_MODEL_PROVIDER=ollama

# --- Google Calendar OAuth (Phase 10, read-only scope only, Docs/SECURITY.md) ---
# Create at console.cloud.google.com: enable the Calendar API, configure the
# OAuth consent screen, create a Web application OAuth client with this exact
# redirect URI registered.
GOOGLE_OAUTH_CLIENT_ID=<your-client-id>.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=<your-client-secret>
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/calendar/oauth/callback

# --- Secret encryption at rest (Docs/SECURITY.md) ---
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_ENCRYPTION_KEY=<generate-a-fernet-key>

# --- Schwab OAuth (Phase 12) ---
# Register at developer.schwab.com: create an app requesting the
# "Accounts and Trading Production" and "Market Data Production" API
# products. No read-only scope exists — Echo enforces read-only by never
# calling a trading endpoint. The callback URL is fixed by the app's own
# registration and is never actually reachable; complete the OAuth flow by
# pasting the resulting dead-page URL into POST /portfolio/schwab/oauth/complete.
SCHWAB_CLIENT_ID=<your-schwab-app-key>
SCHWAB_CLIENT_SECRET=<your-schwab-secret>
SCHWAB_REDIRECT_URI=https://127.0.0.1:8182

# --- Research providers (Phase 15 evaluation harness + Phase 16 domain) ---
# Finnhub and SEC EDGAR were live-tested in Phase 15
# (scripts/provider_evaluation/) and adopted as real Research-domain
# providers in Phase 16 (application/research_provider_factory.py).
# FMP_API_KEY stays evaluation-only — Phase 15 found its v3 API deprecated
# for this key/plan, so nothing adopts it; only the harness reads it.
FINNHUB_API_KEY=<your-finnhub-api-key>
FMP_API_KEY=<your-financial-modeling-prep-api-key>
# Required for SEC EDGAR: its fair-access policy requires a descriptive
# User-Agent with a real, reachable contact address (see
# https://www.sec.gov/os/webmaster-faq) — without it, requests get
# throttled or rejected.
RESEARCH_CONTACT_EMAIL=<your-real-contact-email>

# --- App ---
ECHO_ENV=development
LOG_LEVEL=INFO
